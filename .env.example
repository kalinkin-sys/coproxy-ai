# Required: proxy bearer token (clients use this to authenticate)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
COPROXY_SECRET=

# Optional overrides (defaults shown)
# COPROXY_HOST=127.0.0.1
# COPROXY_PORT=8765
# COPROXY_AUTH_FILE=~/.codex/auth.json
# COPROXY_RATE_LIMIT=30
# COPROXY_LOG_LEVEL=info
# COPROXY_LOG_REQUESTS=false

# TLS/HTTPS (recommended for shared hosting)
# COPROXY_TLS=true
# COPROXY_TLS_CERT_DIR=~/.coproxy/tls

# Unix socket (most secure for shared hosting — owner-only access)
# When set, host:port are ignored. Socket file gets chmod 600.
# COPROXY_UNIX_SOCKET=~/.coproxy/coproxy.sock
